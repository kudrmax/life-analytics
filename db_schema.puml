@startuml life_analytics_db_schema
!pragma layout smetana

!theme plain
skinparam linetype ortho
skinparam roundcorner 5
skinparam class {
    BackgroundColor #FEFEFE
    BorderColor #333333
    ArrowColor #555555
}

hide circle
hide methods

title Life Analytics — Database Schema

entity "users" as users {
    * **id** : SERIAL <<PK>>
    --
    * username : VARCHAR(30) <<UNIQUE>>
    * password_hash : TEXT
    * privacy_mode : BOOLEAN [FALSE]
    * created_at : TIMESTAMPTZ
}

entity "categories" as cat {
    * **id** : SERIAL <<PK>>
    --
    * user_id : INTEGER <<FK>>
    * name : VARCHAR(200)
    parent_id : INTEGER <<FK>>
    * sort_order : INTEGER
    --
    <<UNIQUE INDEX>> (user_id, name)
    WHERE parent_id IS NULL
    --
    <<UNIQUE INDEX>> (user_id, name, parent_id)
    WHERE parent_id IS NOT NULL
}

entity "metric_definitions" as md {
    * **id** : SERIAL <<PK>>
    --
    * user_id : INTEGER <<FK>>
    * slug : VARCHAR(100)
    * name : VARCHAR(200)
    category_id : INTEGER <<FK>>
    * type : metric_type
    * enabled : BOOLEAN
    * sort_order : INTEGER
    * icon : VARCHAR(600)
    * private : BOOLEAN
    * hide_in_cards : BOOLEAN
    * is_checkpoint : BOOLEAN
    * interval_binding : VARCHAR(20)
    description : TEXT
    * created_at : TIMESTAMPTZ
    --
    <<UNIQUE>> (user_id, slug)
}

entity "entries" as entries {
    * **id** : SERIAL <<PK>>
    --
    * metric_id : INTEGER <<FK>>
    * user_id : INTEGER <<FK>>
    * date : DATE
    * recorded_at : TIMESTAMPTZ
    checkpoint_id : INTEGER <<FK>>
    interval_id : INTEGER <<FK>>
    --
    <<UNIQUE INDEX>> (metric_id, user_id, date)
    WHERE checkpoint_id IS NULL AND interval_id IS NULL
    --
    <<UNIQUE INDEX>> (metric_id, user_id, date, checkpoint_id)
    WHERE checkpoint_id IS NOT NULL
    --
    <<UNIQUE INDEX>> (metric_id, user_id, date, interval_id)
    WHERE interval_id IS NOT NULL
}

entity "checkpoints" as checkpoints {
    * **id** : SERIAL <<PK>>
    --
    * user_id : INTEGER <<FK>>
    * label : VARCHAR(100)
    * sort_order : INTEGER
    description : TEXT
    --
    <<UNIQUE INDEX>> (user_id, LOWER(label))
}

entity "intervals" as intervals {
    * **id** : SERIAL <<PK>>
    --
    * user_id : INTEGER <<FK>>
    * start_checkpoint_id : INTEGER <<FK>>
    * end_checkpoint_id : INTEGER <<FK>>
}

entity "metric_checkpoints" as mcheckpoints {
    * **id** : SERIAL <<PK>>
    --
    * metric_id : INTEGER <<FK>>
    * checkpoint_id : INTEGER <<FK>>
    * sort_order : INTEGER
    * enabled : BOOLEAN
    category_id : INTEGER <<FK>>
    --
    <<UNIQUE>> (metric_id, checkpoint_id)
}

entity "metric_intervals" as mintervals {
    * **id** : SERIAL <<PK>>
    --
    * metric_id : INTEGER <<FK>>
    * interval_id : INTEGER <<FK>>
    * sort_order : INTEGER
    * enabled : BOOLEAN
    category_id : INTEGER <<FK>>
    --
    <<UNIQUE>> (metric_id, interval_id)
}

entity "values_bool" as vb {
    * **entry_id** : INTEGER <<PK>> <<FK>>
    --
    * value : BOOLEAN
}

entity "values_time" as vt {
    * **entry_id** : INTEGER <<PK>> <<FK>>
    --
    * value : TIMESTAMPTZ
}

entity "values_number" as vn {
    * **entry_id** : INTEGER <<PK>> <<FK>>
    --
    * value : INTEGER
}

entity "values_scale" as vs {
    * **entry_id** : INTEGER <<PK>> <<FK>>
    --
    * value : INTEGER
    * scale_min : INTEGER
    * scale_max : INTEGER
    * scale_step : INTEGER
}

entity "scale_config" as sc {
    * **metric_id** : INTEGER <<PK>> <<FK>>
    --
    * scale_min : INTEGER
    * scale_max : INTEGER
    * scale_step : INTEGER
    labels : JSONB
}

entity "computed_config" as cc {
    * **metric_id** : INTEGER <<PK>> <<FK>>
    --
    * formula : JSONB
    * result_type : VARCHAR(10)
}

entity "correlation_reports" as cr {
    * **id** : SERIAL <<PK>>
    --
    * user_id : INTEGER <<FK>>
    * status : VARCHAR(20)
    * period_start : DATE
    * period_end : DATE
    * created_at : TIMESTAMPTZ
    finished_at : TIMESTAMPTZ
}

entity "correlation_pairs" as cp {
    * **id** : SERIAL <<PK>>
    --
    * report_id : INTEGER <<FK>>
    metric_a_id : INTEGER
    metric_b_id : INTEGER
    checkpoint_a_id : INTEGER
    checkpoint_b_id : INTEGER
    interval_a_id : INTEGER
    interval_b_id : INTEGER
    * source_key_a : VARCHAR(100)
    * source_key_b : VARCHAR(100)
    * type_a : VARCHAR(20)
    * type_b : VARCHAR(20)
    correlation : FLOAT
    * data_points : INTEGER
    * lag_days : INTEGER
    p_value : FLOAT
    quality_issue : VARCHAR(30)
}

entity "user_integrations" as ui {
    * **id** : SERIAL <<PK>>
    --
    * user_id : INTEGER <<FK>>
    * provider : VARCHAR(50)
    * encrypted_token : TEXT
    * enabled : BOOLEAN
    * created_at : TIMESTAMPTZ
    --
    <<UNIQUE>> (user_id, provider)
}

entity "integration_config" as ic {
    * **metric_id** : INTEGER <<PK>> <<FK>>
    --
    * provider : VARCHAR(50)
    * metric_key : VARCHAR(100)
    * value_type : VARCHAR(20)
}

entity "integration_filter_config" as ifc {
    * **metric_id** : INTEGER <<PK>> <<FK>>
    --
    * filter_name : VARCHAR(200)
}

entity "integration_query_config" as iqc {
    * **metric_id** : INTEGER <<PK>> <<FK>>
    --
    * filter_query : VARCHAR(1024)
}

entity "activitywatch_settings" as aws {
    * **user_id** : INTEGER <<PK>> <<FK>>
    --
    * enabled : BOOLEAN
    * aw_url : VARCHAR(500)
    * created_at : TIMESTAMPTZ
}

entity "activitywatch_daily_summary" as ads {
    * **id** : SERIAL <<PK>>
    --
    * user_id : INTEGER <<FK>>
    * date : DATE
    * total_seconds : INTEGER
    * active_seconds : INTEGER
    * synced_at : TIMESTAMPTZ
    first_activity_time : TIMESTAMPTZ
    last_activity_time : TIMESTAMPTZ
    afk_seconds : INTEGER
    longest_session_seconds : INTEGER
    context_switches : INTEGER
    break_count : INTEGER
    --
    <<UNIQUE>> (user_id, date)
}

entity "activitywatch_app_usage" as aau {
    * **id** : SERIAL <<PK>>
    --
    * user_id : INTEGER <<FK>>
    * date : DATE
    * app_name : VARCHAR(500)
    * source : VARCHAR(20)
    * duration_seconds : INTEGER
    --
    <<UNIQUE>> (user_id, date, app_name, source)
}

entity "activitywatch_categories" as acat {
    * **id** : SERIAL <<PK>>
    --
    * user_id : INTEGER <<FK>>
    * name : VARCHAR(200)
    color : VARCHAR(7)
    * sort_order : INTEGER
    --
    <<UNIQUE>> (user_id, name)
}

entity "activitywatch_app_category_map" as aacm {
    * **id** : SERIAL <<PK>>
    --
    * user_id : INTEGER <<FK>>
    * app_name : VARCHAR(500)
    * activitywatch_category_id : INTEGER <<FK>>
    --
    <<UNIQUE>> (user_id, app_name)
}

entity "integration_category_config" as icatc {
    * **metric_id** : INTEGER <<PK>> <<FK>>
    --
    * activitywatch_category_id : INTEGER <<FK>>
}

entity "integration_app_config" as iapc {
    * **metric_id** : INTEGER <<PK>> <<FK>>
    --
    * app_name : VARCHAR(500)
}

entity "enum_config" as ec {
    * **metric_id** : INTEGER <<PK>> <<FK>>
    --
    * multi_select : BOOLEAN
}

entity "enum_options" as eo {
    * **id** : SERIAL <<PK>>
    --
    * metric_id : INTEGER <<FK>>
    * sort_order : INTEGER
    * label : VARCHAR(200)
    * enabled : BOOLEAN
}

entity "notes" as notes {
    * **id** : SERIAL <<PK>>
    --
    * metric_id : INTEGER <<FK>>
    * user_id : INTEGER <<FK>>
    * date : DATE
    * text : TEXT
    * created_at : TIMESTAMPTZ
    --
    <<INDEX>> (metric_id, user_id, date)
}

entity "metric_condition" as mcond {
    * **metric_id** : INTEGER <<PK>> <<FK>>
    --
    * depends_on_metric_id : INTEGER <<FK>>
    * condition_type : VARCHAR(20)
    condition_value : JSONB
    --
    <<INDEX>> (depends_on_metric_id)
}

entity "values_duration" as vdu {
    * **entry_id** : INTEGER <<PK>> <<FK>>
    --
    * value : INTEGER
}

entity "values_enum" as ve {
    * **entry_id** : INTEGER <<PK>> <<FK>>
    --
    * selected_option_ids : INTEGER[]
}

entity "insights" as ins {
    * **id** : SERIAL <<PK>>
    --
    * user_id : INTEGER <<FK>>
    * text : TEXT
    * created_at : TIMESTAMPTZ
    * updated_at : TIMESTAMPTZ
}

entity "insight_metrics" as insm {
    * **id** : SERIAL <<PK>>
    --
    * insight_id : INTEGER <<FK>>
    metric_id : INTEGER <<FK>>
    custom_label : VARCHAR(200)
    * sort_order : INTEGER
}

' ── Relationships ──

users ||--o{ cat : "user_id"
users ||--o{ md : "user_id"
users ||--o{ entries : "user_id"
users ||--o{ cr : "user_id"
users ||--o{ ui : "user_id"
users ||--o{ aws : "user_id"
users ||--o{ ads : "user_id"
users ||--o{ aau : "user_id"
users ||--o{ acat : "user_id"
users ||--o{ aacm : "user_id"
users ||--o{ notes : "user_id"
users ||--o{ ins : "user_id"

cat ||--o{ cat : "parent_id"
cat ||--o{ md : "category_id"
cat ||--o{ mcheckpoints : "category_id"
cat ||--o{ mintervals : "category_id"

users ||--o{ checkpoints : "user_id"
users ||--o{ intervals : "user_id"

md ||--o{ entries : "metric_id"
md ||--o{ mcheckpoints : "metric_id"
md ||--o{ mintervals : "metric_id"
md ||--o| sc : "metric_id"
md ||--o| cc : "metric_id"
md ||--o| ic : "metric_id"
md ||--o| ifc : "metric_id"
md ||--o| iqc : "metric_id"
md ||--o| icatc : "metric_id"
md ||--o| iapc : "metric_id"
md ||--o| ec : "metric_id"
md ||--o{ eo : "metric_id"
md ||--o{ notes : "metric_id"
md ||--o| mcond : "metric_id"
md ||--o{ mcond : "depends_on_metric_id"

checkpoints ||--o{ entries : "checkpoint_id"
checkpoints ||--o{ mcheckpoints : "checkpoint_id"
checkpoints ||--o{ intervals : "start_checkpoint_id"
checkpoints ||--o{ intervals : "end_checkpoint_id"

intervals ||--o{ entries : "interval_id"
intervals ||--o{ mintervals : "interval_id"

entries ||--o| vb : "entry_id"
entries ||--o| vt : "entry_id"
entries ||--o| vn : "entry_id"
entries ||--o| vs : "entry_id"
entries ||--o| vdu : "entry_id"
entries ||--o| ve : "entry_id"

cr ||--o{ cp : "report_id"

ins ||--o{ insm : "insight_id"
md ||--o{ insm : "metric_id"

acat ||--o{ aacm : "activitywatch_category_id"
acat ||--o{ icatc : "activitywatch_category_id"

@enduml
